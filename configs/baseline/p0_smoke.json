{
  "schema_version": 1,
  "name": "p0-smoke",
  "description": "Synthetic 32x32 pipeline validation; not a report-grade experiment.",
  "backend": "third_party/stylegan2-ada-pytorch",
  "data": "data/processed/p0-shapes-32.zip",
  "outdir": "results/runs/p0-smoke",
  "samples_outdir": "results/samples/p0-smoke",
  "smoke_metric_output": "results/tables/p0-smoke-metric.json",
  "train": {
    "gpus": 1,
    "cfg": "auto",
    "cond": false,
    "mirror": false,
    "aug": "ada",
    "augpipe": "blit",
    "target": 0.6,
    "kimg": 1,
    "snap": 1,
    "metrics": "none",
    "batch": 32,
    "nobench": true,
    "workers": 4,
    "seed": 42
  },
  "generate": {
    "seeds": "0-63",
    "trunc": 1.0
  },
  "evaluate": {
    "metrics": "fid50k_full",
    "gpus": 1
  }
}
