{
  "schema_version": 1,
  "name": "p1-afhqcat512-short",
  "description": "AFHQ Cat 512x512 short baseline run for data, throughput, snapshot, generation, and metric-path validation.",
  "backend": "third_party/stylegan2-ada-pytorch",
  "data": "data/processed/afhqcat-512.zip",
  "outdir": "results/runs/p1-afhqcat512-short",
  "samples_outdir": "results/samples/p1-afhqcat512-short",
  "train": {
    "gpus": 1,
    "cfg": "paper512",
    "cond": false,
    "mirror": true,
    "aug": "ada",
    "augpipe": "bgc",
    "target": 0.6,
    "kimg": 100,
    "snap": 10,
    "metrics": "none",
    "workers": 8,
    "seed": 42
  },
  "generate": {
    "seeds": "0-63",
    "trunc": 1.0
  },
  "evaluate": {
    "metrics": "fid50k_full",
    "gpus": 1
  }
}
