{
  "schema_version": 1,
  "name": "p2-lsun-church256-100k-noada-seed1-1500",
  "description": "Second-seed repeat of the E2 no-augmentation control (100k, noaug) at 1500 kimg, for estimating seed variance on the ADA on/off axis. Identical to E2 except seed=1.",
  "backend": "third_party/stylegan2-ada-pytorch",
  "data": "data/processed/lsun-church-256-100k.zip",
  "outdir": "results/runs/p2-lsun-church256-100k-noada-seed1-1500",
  "samples_outdir": "results/samples/p2-lsun-church256-100k-noada-seed1-1500",
  "train": {
    "gpus": 2,
    "cfg": "paper256",
    "cond": false,
    "mirror": true,
    "aug": "noaug",
    "kimg": 1500,
    "snap": 25,
    "metrics": "none",
    "workers": 8,
    "seed": 1
  },
  "generate": {
    "seeds": "0-63",
    "trunc": 1.0
  },
  "evaluate": {
    "metrics": "fid50k_full,kid50k_full,pr50k3_full",
    "mirror": false,
    "gpus": 2
  }
}
