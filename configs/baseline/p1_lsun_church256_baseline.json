{
  "schema_version": 1,
  "name": "p1-lsun-church256-100k-baseline",
  "description": "LSUN Church Outdoor 256x256 100k subset StyleGAN2-ADA baseline candidate for P1 reproduction.",
  "backend": "third_party/stylegan2-ada-pytorch",
  "data": "data/processed/lsun-church-256-100k.zip",
  "outdir": "results/runs/p1-lsun-church256-100k-baseline",
  "samples_outdir": "results/samples/p1-lsun-church256-100k-baseline",
  "train": {
    "gpus": 2,
    "cfg": "paper256",
    "cond": false,
    "mirror": true,
    "aug": "ada",
    "augpipe": "bgc",
    "target": 0.6,
    "kimg": 2000,
    "snap": 25,
    "metrics": "fid50k_full",
    "workers": 8,
    "seed": 42
  },
  "generate": {
    "seeds": "0-63",
    "trunc": 1.0
  },
  "evaluate": {
    "metrics": "fid50k_full,kid50k_full,pr50k3_full",
    "mirror": false,
    "gpus": 2
  }
}
