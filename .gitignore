/third_party/stylegan2-ada-pytorch/

# Local environments and caches.
/.venv/
/env/
__pycache__/
*.py[cod]
.pytest_cache/
.pycache_tmp/
.idea/
.vscode/

# Large and generated experiment artifacts.
/*.tar.gz
/data/raw/
/data/downloads/
/data/processed/
/checkpoints/*
!/checkpoints/README.md
/results/runs/
/results/logs/*
!/results/logs/.gitkeep
/results/samples/*
!/results/samples/.gitkeep
/results/tables/*
!/results/tables/.gitkeep
/results/figures/*
!/results/figures/.gitkeep
/results/analysis/*
!/results/analysis/.gitkeep
/results/nn/*
!/results/nn/.gitkeep

# Course materials currently kept outside version control.
/report/course_materials/*.doc
/report/course_materials/*.pdf
